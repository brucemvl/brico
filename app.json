{
  "expo": {
    "name": "Briconnect",
    "slug": "briconnect",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/briconnectICON2.png",
    "scheme": "bricoconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.brico.app",
  "CFBundleLocalizations": "fr",
  "infoPlist": {
    "ITSAppUsesNonExemptEncryption": false,
    "NSPhotoLibraryUsageDescription": "Cette application accède à vos photos pour vous permettre d’ajouter des images à vos demandes de travaux ou à votre profil.",
    "NSCameraUsageDescription": "Cette application utilise la caméra pour vous permettre de prendre des photos de vos travaux ou missions."
  }
},
    "android": {
      "icon": "./assets/images/briconnectICON2.png",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/briconnectICON2.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bmdev14.bricoconnect"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/briconnectICON.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/briconnectICON2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "514fdd8f-34fa-4f61-8811-64c37b1ab983"
      }
    },
    "owner": "bmdev14"
  }
}
